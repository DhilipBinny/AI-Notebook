# ===========================================
# AI Notebook - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Used by both docker-compose files:
#   docker-compose -f docker-compose.infra.yml up -d
#   docker-compose -f docker-compose.apps.yml up -d
# ===========================================

# === Application ===
# APP_ENV=development
# APP_DEBUG=true

# === Database ===
MYSQL_ROOT_PASSWORD=change_me_to_secure_password
MYSQL_DATABASE=ainotebook
DATABASE_URL=mysql+aiomysql://root:${MYSQL_ROOT_PASSWORD}@ainotebook-mysql:3306/${MYSQL_DATABASE}

# === S3/MinIO ===
S3_ENDPOINT=http://ainotebook-minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_to_secure_password
S3_BUCKET_NOTEBOOKS=notebooks

# === JWT Authentication ===
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_random_64_char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === Encryption (for DB-stored API keys) ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === OAuth Providers (optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8001

# === OpenAI-Compatible Providers ===
# Ollama, OpenRouter, vLLM, etc. are configured via Admin UI (Platform Keys)
# No env vars needed - base_url, api_key, and model are stored in DB

# === Playground Container Settings ===
PLAYGROUND_IMAGE=ainotebook-playground:latest
PLAYGROUND_NETWORK=ainotebook-network
# PLAYGROUND_MEMORY_LIMIT=2g
# PLAYGROUND_CPU_LIMIT=1.0
# PLAYGROUND_IDLE_TIMEOUT=3600

# === AI Cell Streaming ===
AI_CELL_STREAMING_ENABLED=true

# === CORS ===
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8001

# === User Limits ===
# DEFAULT_MAX_PROJECTS=5
