# =====================================================
# AI Notebook Platform - Environment Variables
# =====================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =====================================================

# =====================================================
# MySQL Database
# =====================================================
MYSQL_ROOT_PASSWORD=change_me_to_secure_password
MYSQL_DATABASE=ainotebook

# Full connection URL (for application use)
# Format: mysql+aiomysql://user:password@host:port/database
DATABASE_URL=mysql+aiomysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/${MYSQL_DATABASE}

# =====================================================
# Redis
# =====================================================
REDIS_URL=redis://redis:6379/0

# =====================================================
# MinIO (S3-compatible storage)
# =====================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_to_secure_password

# S3 client configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET_NOTEBOOKS=notebooks
S3_BUCKET_OUTPUTS=outputs
S3_BUCKET_AVATARS=avatars
S3_REGION=us-east-1

# =====================================================
# JWT Authentication
# =====================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_random_64_char_string_use_openssl_rand
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =====================================================
# NextAuth.js (Frontend auth)
# =====================================================
# Must match your deployment URL
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_to_random_secret

# =====================================================
# OAuth Providers (Optional)
# =====================================================
# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =====================================================
# Playground Container Settings
# =====================================================
PLAYGROUND_IMAGE=ainotebook/playground:latest
PLAYGROUND_NETWORK=ainotebook-network

# Resource limits per container
PLAYGROUND_MEMORY_LIMIT=2g
PLAYGROUND_CPU_LIMIT=1.0
PLAYGROUND_STORAGE_LIMIT=5g

# Timeouts (in seconds)
PLAYGROUND_IDLE_TIMEOUT=3600       # 1 hour
PLAYGROUND_MAX_LIFETIME=14400      # 4 hours
PLAYGROUND_STARTUP_TIMEOUT=60      # 1 minute

# Maximum concurrent playgrounds per user
PLAYGROUND_MAX_PER_USER=2

# =====================================================
# LLM Configuration
# =====================================================
# Default provider for new playgrounds
DEFAULT_LLM_PROVIDER=ollama

# Ollama (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# =====================================================
# Application Settings
# =====================================================
# Environment: development, staging, production
APP_ENV=development
APP_DEBUG=true

# Master API
MASTER_API_HOST=0.0.0.0
MASTER_API_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:3000

# =====================================================
# Logging
# =====================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =====================================================
# Security
# =====================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60
