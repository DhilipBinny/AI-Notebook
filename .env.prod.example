# AI Notebook - Production Environment Variables
# Copy this to .env and fill in your values

# Database (MySQL)
DATABASE_URL=mysql+aiomysql://root:YOUR_MYSQL_PASSWORD@ainotebook-mysql:3306/ainotebook

# Redis
REDIS_URL=redis://ainotebook-redis:6379/0

# S3/MinIO
S3_ENDPOINT=http://ainotebook-minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=YOUR_MINIO_SECRET

# JWT Secret - CHANGE THIS! Use: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_32_CHARS

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost,http://10.0.2.21

# Playground Network (check with: docker network ls | grep ainotebook)
# The network name often has a prefix from docker-compose project name
PLAYGROUND_NETWORK=ai-jupyter_ainotebook-network
